{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mushoku-chronicles",
  "compatibility_date": "2026-03-12",
  "main": "worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
